# .env.example for Production Deployment
# Copy to .env and fill values

# Django
SECRET_KEY=your-super-secret-key-change-in-prod
DEBUG=False
ALLOWED_HOSTS=*,yourdomain.com,147.45.100.23
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://yourdomain.com,https://yourdomain.com

# Database (Postgres in docker-compose)
DATABASE_NAME=adbook_prod
DATABASE_USER=adbook
DATABASE_PASSWORD=strongpassword123
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Redis (default in docker-compose: redis://redis:6379/0)
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# Celery (uses REDIS_URL)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (optional, configure if needed)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Security
SECURE_SSL_REDIRECT=False  # Set True if HTTPS

# Docker volumes persist data automatically

